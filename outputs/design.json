{
  "design_system": {
    "colors": {
      "background": "#0a0a0a",
      "surface": "#141414",
      "primary": "#00ff9f",
      "accent": "#00c3ff",
      "text_primary": "#e6e6e6",
      "text_secondary": "#a0a0a0",
      "border": "#333333",
      "error": "#ff4d4d",
      "success": "#00ff9f"
    },
    "typography": {
      "font_family_headings": "'Space Grotesk', sans-serif",
      "font_family_body": "'Inter', sans-serif",
      "font_family_mono": "'JetBrains Mono', monospace",
      "font_sizes": {
        "h1": "3.5rem",
        "h2": "2.25rem",
        "h3": "1.5rem",
        "body": "1rem",
        "small": "0.875rem"
      }
    },
    "shadows": {
      "glow_primary": "0 0 10px rgba(0, 255, 159, 0.3)",
      "glow_accent": "0 0 10px rgba(0, 195, 255, 0.3)"
    },
    "components": {
      "terminal_card": {
        "border_radius": "4px",
        "background": "#141414",
        "border": "1px solid #333333",
        "header": {
          "show_dots": true,
          "dots_colors": ["#ff5f56", "#ffbd2e", "#27c93f"]
        }
      },
      "code_block": {
        "background": "#0f0f0f",
        "border_radius": "4px",
        "padding": "1rem",
        "font_family": "monospace"
      },
      "button_primary": {
        "background": "transparent",
        "border": "1px solid #00ff9f",
        "color": "#00ff9f",
        "hover": {
          "background": "rgba(0, 255, 159, 0.1)",
          "glow": true
        }
      }
    },
    "animations": {
      "typing_effect": {
        "cursor": "|",
        "speed": "50ms"
      },
      "fade_in": {
        "duration": "0.3s",
        "timing": "ease-out"
      }
    }
  },
  "layout": {
    "max_width": "1200px",
    "breakpoints": {
      "mobile": "640px",
      "tablet": "768px",
      "desktop": "1024px"
    },
    "spacing": {
      "section": "6rem",
      "component": "2rem"
    }
  }
}
